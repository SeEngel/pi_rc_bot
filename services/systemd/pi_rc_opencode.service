[Unit]
Description=pi_rc_bot OpenCode Supervisor (observe → think → act → remember)
Wants=pi_rc_brain_services.service pi_rc_move_services.service network-online.target
After=network-online.target pi_rc_brain_services.service pi_rc_move_services.service

[Service]
Type=simple
WorkingDirectory=%h/Desktop/pi_rc_bot/OpenCode
ExecStartPre=%h/Desktop/pi_rc_bot/scripts/wait_for_network.sh
ExecStartPre=/usr/bin/sleep 5
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-%h/Desktop/pi_rc_bot/.env
ExecStart=/usr/bin/env uv run python main.py
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
